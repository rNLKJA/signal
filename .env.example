# Signal — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# .env is gitignored; never commit a real key.
#
# Local run picks it up with:  uvicorn signalkit.api:app --env-file .env
# Deployment: the key goes to Modal as a secret, not via this file:
#   modal secret create signal-llm SIGNAL_LLM_API_KEY=<your-key>

# --- LLM narrative layer (optional — without a key, answers use the
# --- deterministic template and the product works fully) ---------------

# Your LLM API key. DeepSeek keys come from https://platform.deepseek.com
SIGNAL_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI-compatible endpoint. Defaults shown (DeepSeek).
SIGNAL_LLM_BASE_URL=https://api.deepseek.com

# Model to use for phrasing narratives.
SIGNAL_LLM_MODEL=deepseek-chat

# Recorded as model_provider in every audit entry.
SIGNAL_LLM_PROVIDER=DeepSeek

# --- Data layer --------------------------------------------------------

# Set to 1 to skip the live SA Police data.gov.au API entirely (snapshot only).
# SIGNAL_OFFLINE=1

# Where the governance decision log is written (default: logs/decisions.jsonl).
# SIGNAL_LOG_PATH=logs/decisions.jsonl
